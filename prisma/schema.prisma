generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  manager
  support
  designer
  production
  customer
  auditor
}

enum ProductType {
  seal
  ink
}

enum StockAction {
  ADD
  SALE
  REMOVE
  RETURN
  ADJUSTMENT
}

model User {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String   @unique
  password    String
  role        Role     @default(customer)
  isTrashed   Boolean  @default(false)
  image       String?
  basicSalary Float    @default(0)
  overtime    Float    @default(0)
  ta          Float    @default(0)
  bonus       Float    @default(0)
  createdAt   DateTime @default(now())
}

model GeneralSettings {
  id              Int      @id @default(autoincrement())
  siteTitle       String?
  siteDescription String?
  logo            String?
  favicon         String?
  email           String?
  phone           String?
  address         String?
  supportEmail    String?
  facebook        String?
  instagram       String?
  twitter         String?
  linkedin        String?
  youtube         String?
  tiktok          String?
  whatsapp        String?
  telegram        String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[]
  metaImage       String?
  footerText      String?
  deliveryFree            Boolean  @default(false)
  deliveryInsideDhaka     Float    @default(60)
  deliveryOutsideDhaka    Float    @default(120)
  banners         Banner[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Banner {
  id           Int             @id @default(autoincrement())
  desktopImage String
  mobileImage  String
  link         String?
  order        Int             @default(0)
  settingsId   Int
  settings     GeneralSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model Product {
  id             Int              @id @default(autoincrement())
  title          String
  slug           String           @unique
  description    String?
  seoTitle       String?
  seoDescription String?
  keywords       String[]
  type           ProductType
  totalStock     Int              @default(0)
  isTrashed      Boolean          @default(false)
  isFreeGift     Boolean          @default(false)
  variants       ProductVariant[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ProductVariant {
  id            Int            @id @default(autoincrement())
  productId     Int
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  title         String
  size          String?
  color         String?
  regularPrice  Float
  salePrice     Float
  purchasePrice Float
  stock         Int            @default(0)
  sku           String         @unique
  images        String[]
  isDefault     Boolean        @default(false)
  isActive      Boolean        @default(true)
  stockHistory  StockHistory[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model StockHistory {
  id        Int         @id @default(autoincrement())
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  action    StockAction
  quantity  Int
  note      String?
  createdAt DateTime    @default(now())
}

enum OrderStatus {
  Processing
  WaitForDesign
  DesignSubmitted
  Revision
  CustomerInformed
  NeedToCall
  NoResponse
  OrderConfirmed
  InProduction
  InReview
  Pending
  Delivered
  PartlyDelivered
  Cancel
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

model Order {
  id              Int           @id @default(autoincrement())
  customerName    String
  customerPhone   String
  alternativePhone String?
  address         String
  items           OrderItem[]
  subtotal        Float
  deliveryCharge  Float
  total           Float
  status          OrderStatus   @default(Processing)
  discount        Float         @default(0)
  discountPercent Float         @default(0)
  paidAmount      Float         @default(0)
  paymentStatus   PaymentStatus @default(unpaid)
  paidAt          DateTime?
  confirmedAt     DateTime?
  isTrashed       Boolean       @default(false)
  stockDeducted   Boolean       @default(false)
  note            String?
  contactLink     String?
  transactions    PaymentTransaction[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PaymentTransaction {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Float
  source    String?
  trxId     String?
  note      String?
  createdAt DateTime @default(now())
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId   Int
  title       String
  price       Float
  quantity    Int
  sealText    String?
  isFreeItem  Boolean @default(false)
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  website   String?
  facebook  String?
  isTrashed Boolean    @default(false)
  purchases Purchase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum PurchaseStatus {
  Pending
  Ordered
  Received
}

model Purchase {
  id            Int            @id @default(autoincrement())
  supplierId    Int?
  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  date          DateTime
  status        PurchaseStatus @default(Pending)
  totalAmount   Float
  purchaseMoney Float?
  orderedAt     DateTime?
  note          String?
  stockUpdated  Boolean        @default(false)
  receivedAt    DateTime?
  isTrashed     Boolean        @default(false)
  items         PurchaseItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PurchaseItem {
  id            Int      @id @default(autoincrement())
  purchaseId    Int
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variantId     Int
  variantTitle  String
  productTitle  String
  quantity      Int
  purchasePrice Float
}

model OfficeExpenseCategory {
  id        Int             @id @default(autoincrement())
  name      String
  status    String          @default("active")
  createdBy Int?
  isTrashed Boolean         @default(false)
  expenses  OfficeExpense[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("office_expense_categories")
}

model OfficeExpense {
  id         Int                   @id @default(autoincrement())
  categoryId Int
  category   OfficeExpenseCategory @relation(fields: [categoryId], references: [id])
  note       String
  amount     Float
  createdBy  Int?
  isTrashed  Boolean               @default(false)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@map("office_expenses")
}

model MarketingExpenseCategory {
  id        Int                @id @default(autoincrement())
  name      String
  status    String             @default("active")
  createdBy Int?
  isTrashed Boolean            @default(false)
  expenses  MarketingExpense[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@map("marketing_expense_categories")
}

model MarketingExpense {
  id         Int                      @id @default(autoincrement())
  categoryId Int
  category   MarketingExpenseCategory @relation(fields: [categoryId], references: [id])
  note       String
  amount     Float
  createdBy  Int?
  isTrashed  Boolean                  @default(false)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@map("marketing_expenses")
}

model FinancialActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int
  note      String?
  amount    Float?
  createdAt DateTime @default(now())

  @@map("financial_activity_logs")
}

model Payroll {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  salaryMonth    String   // "YYYY-MM"
  basicSalary    Float
  overtime       Float    @default(0)
  ta             Float    @default(0)
  bonus          Float    @default(0)
  totalPayable   Float
  status         String   @default("Pending") // "Pending" | "Paid"
  note           String?
  paidAt         DateTime?
  isTrashed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("payrolls")
}
